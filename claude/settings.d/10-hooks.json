{
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "zsh \"$XDG_CONFIG_HOME/claude/hooks/notify.zsh\"",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "zsh \"$XDG_CONFIG_HOME/claude/hooks/no-ai-comments.zsh\"",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|Bash"
      },
      {
        "hooks": [
          {
            "command": "zsh \"$XDG_CONFIG_HOME/claude/hooks/no-emojis.zsh\"",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "zsh \"$XDG_CONFIG_HOME/claude/hooks/auto-approve-reads.zsh\"",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "zsh \"$XDG_CONFIG_HOME/claude/hooks/agent-transparency.zsh\"",
            "type": "command"
          }
        ],
        "matcher": "Agent"
      },
      {
        "hooks": [
          {
            "command": "zsh \"$XDG_CONFIG_HOME/claude/hooks/secret-scan.zsh\"",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      },
      {
        "hooks": [
          {
            "command": "zsh \"$XDG_CONFIG_HOME/claude/hooks/block-destructive.zsh\"",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "zsh \"$XDG_CONFIG_HOME/claude/hooks/post-compact.zsh\"",
            "type": "command"
          }
        ],
        "matcher": "compact"
      }
    ]
  }
}
