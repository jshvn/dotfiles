{
  "agentPushNotifEnabled": true,
  "effortLevel": "max",
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(bat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(fd *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(diff *)",
      "Bash(which *)",
      "Bash(command -v *)",
      "Bash(type *)",
      "Bash(env *)",
      "Bash(printenv *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(pwd *)",
      "Bash(whoami *)",
      "Bash(uname *)",
      "Bash(date *)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(tree *)",
      "Bash(awk *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(ag *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(cut *)",
      "Bash(tr *)",
      "Bash(column *)",
      "Bash(tac *)",
      "Bash(rev *)",
      "Bash(nl *)",
      "Bash(paste *)",
      "Bash(comm *)",
      "Bash(join *)",
      "Bash(fold *)",
      "Bash(fmt *)",
      "Bash(expand *)",
      "Bash(unexpand *)",
      "Bash(look *)",
      "Bash(basename *)",
      "Bash(dirname *)",
      "Bash(realpath *)",
      "Bash(readlink *)",
      "Bash(ps *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(uptime *)",
      "Bash(hostname *)",
      "Bash(arch *)",
      "Bash(id *)",
      "Bash(groups *)",
      "Bash(who *)",
      "Bash(w *)",
      "Bash(last *)",
      "Bash(users *)",
      "Bash(tty *)",
      "Bash(locale *)",
      "Bash(iconv *)",
      "Bash(sw_vers *)",
      "Bash(system_profiler *)",
      "Bash(vm_stat *)",
      "Bash(iostat *)",
      "Bash(sysctl -n *)",
      "Bash(sysctl -a *)",
      "Bash(xxd *)",
      "Bash(od *)",
      "Bash(strings *)",
      "Bash(hexdump *)",
      "Bash(shasum *)",
      "Bash(md5 *)",
      "Bash(md5sum *)",
      "Bash(sha1sum *)",
      "Bash(sha256sum *)",
      "Bash(sha512sum *)",
      "Bash(cksum *)",
      "Bash(mdfind *)",
      "Bash(mdls *)",
      "Bash(locate *)",
      "Bash(ifconfig *)",
      "Bash(ipconfig *)",
      "Bash(netstat *)",
      "Bash(lsof *)",
      "Bash(dig *)",
      "Bash(nslookup *)",
      "Bash(host *)",
      "Bash(traceroute *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(git remote *)",
      "Bash(git rev-parse *)",
      "Bash(git tag *)",
      "Bash(git stash list *)",
      "Bash(git blame *)",
      "Bash(task *)",
      "Bash(python3 -m json.tool *)",
      "Bash(python3 -c *)",
      "Bash(shellcheck *)",
      "Bash(shfmt *)",
      "Bash(ruff check *)",
      "Bash(ruff format --check *)",
      "Bash(biome *)",
      "Bash(taplo *)",
      "Bash(whois *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/secrets/*)",
      "Read(**/*credential*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/.ssh/id_rsa)",
      "Read(**/.ssh/id_ed25519)",
      "Read(**/.ssh/id_ecdsa)",
      "Read(**/.ssh/id_dsa)",
      "Read(**/.ssh/*_rsa)",
      "Read(**/.ssh/*_ed25519)",
      "Read(**/.ssh/*_ecdsa)",
      "Read(**/.ssh/*_key)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "zsh \"$XDG_CONFIG_HOME/claude/hooks/notify.zsh\"",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "zsh \"$XDG_CONFIG_HOME/claude/hooks/no-ai-comments.zsh\"",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|Bash"
      },
      {
        "hooks": [
          {
            "command": "zsh \"$XDG_CONFIG_HOME/claude/hooks/no-emojis.zsh\"",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "zsh \"$XDG_CONFIG_HOME/claude/hooks/auto-approve-reads.zsh\"",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "zsh \"$XDG_CONFIG_HOME/claude/hooks/agent-transparency.zsh\"",
            "type": "command"
          }
        ],
        "matcher": "Agent"
      },
      {
        "hooks": [
          {
            "command": "zsh \"$XDG_CONFIG_HOME/claude/hooks/secret-scan.zsh\"",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|Bash"
      },
      {
        "hooks": [
          {
            "command": "zsh \"$XDG_CONFIG_HOME/claude/hooks/block-destructive.zsh\"",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "command": "zsh \"$XDG_CONFIG_HOME/claude/hooks/post-compact.zsh\"",
            "type": "command"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "command": "CLAUDE_PLUGIN_ROOT=\"$HOME/.claude\" node \"$HOME/.claude/scripts/hooks/session-start-bootstrap.js\"",
            "type": "command"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "CLAUDE_PLUGIN_ROOT=\"$HOME/.claude\" node \"$HOME/.claude/scripts/hooks/pre-compact.js\"",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "CLAUDE_PLUGIN_ROOT=\"$HOME/.claude\" node \"$HOME/.claude/scripts/hooks/session-end.js\"",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "env": {
    "ECC_SESSION_START_MAX_CHARS": "4000"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "ecc": {
      "source": {
        "source": "git",
        "url": "https://github.com/affaan-m/everything-claude-code.git"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "model": "opus[1m]",
  "tui": "fullscreen"
}
