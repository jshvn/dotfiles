# identity/ssh/identities/server-2 -- server-2 SSH identity.
#
# Symlinked as ~/.ssh/identities/active when identity.ssh = "server-2".
# Included via the Include directive in identity/ssh/config -> ~/.ssh/config.
# Side effects: uses the local system ssh-agent (not 1Password). The deploy key
#   id_ed25519_server-2 is generated locally on the server at cutover time (D-09)
#   and is never committed to this repo.
# IdentityFile path update vs v1: ~/.ssh/id_ed25519_server -> ~/.ssh/id_ed25519_server-2 (D-06)

# Server-2 profile uses the system ssh-agent (not 1Password)
# Deploy key for github.com is managed locally and loaded into ssh-agent

Host github.com
    IdentityFile ~/.ssh/id_ed25519_server-2
    IdentitiesOnly yes
    AddKeysToAgent yes
