# identity/ssh/identities/atium -- atium SSH identity.
#
# Symlinked as ~/.ssh/identities/active when identity.ssh = "atium".
# Included via the Include directive in identity/ssh/config -> ~/.ssh/config.
# Side effects: uses the local system ssh-agent (not 1Password). Each GitHub repo on atium
#   has its own deploy key, routed via a host alias. The deploy keys are generated locally
#   on atium at first install and are never committed to this repo.
#
# Usage: set each repo's origin to the matching alias hostname:
#   git remote set-url origin git@github.com-jgrid:jshvn/jgrid.net.git
#   git remote set-url origin git@github.com-dotfiles:jshvn/dotfiles.git
#
# Bare `github.com` is intentionally not configured. Any clone using the unaliased host
# fails loudly, forcing the operator to pick the right alias and matching deploy key.
# Adding a new repo: register the deploy key on the repo, drop the private key at
# ~/.ssh/id_ed25519_atium_<slug>, and add a new Host github.com-<slug> block below.

Host github.com-jgrid
    Hostname github.com
    User git
    IdentityFile ~/.ssh/id_ed25519_atium_jgrid
    IdentitiesOnly yes
    AddKeysToAgent yes

Host github.com-dotfiles
    Hostname github.com
    User git
    IdentityFile ~/.ssh/id_ed25519_atium_dotfiles
    IdentitiesOnly yes
    AddKeysToAgent yes
