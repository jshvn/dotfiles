# identity/git/identities/work -- work git identity overlay.
#
# Loaded via [includeIf "gitdir/i:~/git/work/"] in identity/git/config.
# Overrides: [user] name; [gpg] format + program; [commit] gpgsign.
# Side effects: enables 1Password SSH signing for all repos under ~/git/work/.
# Requires: features.one-password-signing = true in the machine manifest (D-16).
#
# Note: work email is not yet set. Fill in before activating work identity.
# Open question tracked in .planning/phases/04-identity-layer-git-ssh-per-machine/04-CONTEXT.md.

[user]
    name = Josh Vaughen
    # TODO: set work email before merge -- email = <work>

[gpg]
    format = ssh

[gpg "ssh"]
    program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"

[commit]
    gpgsign = true
