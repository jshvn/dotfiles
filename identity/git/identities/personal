# identity/git/identities/personal -- personal git identity overlay.
#
# Loaded via [includeIf "gitdir/i:~/git/personal/"] in identity/git/config.
# Overrides: [user] email, signingkey; [github] user; [gpg] format + program; [commit] gpgsign.
# Side effects: enables 1Password SSH signing for all repos under ~/git/personal/.
# Requires: features.one-password-signing = true in the machine manifest (D-16).

[user]
    name = Josh Vaughen
    email = josh@vaughen.net
    signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIMsU4L+sNRYKBy7p294G4YVbsjT4O4ewT9OTnKbfnfdT

[github]
    user = jshvn

[gpg]
    format = ssh

[gpg "ssh"]
    program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"

[commit]
    gpgsign = true
